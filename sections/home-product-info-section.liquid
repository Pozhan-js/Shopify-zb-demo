{% comment %}
  Product Info Section - Multi-SKU Support
  Displays current product information from Shopify product object
  Auto-fetches first product from collections if no specific product is set
  Supports backend editing through section settings
{% endcomment %}

<style>
  .product-info-section {
    padding: {{ section.settings.paddingtop | times: 0.5 | round: 0 }}px 0 {{ section.settings.paddingbottom | times: 0.5 | round: 0 }}px 0;
    background: {{ section.settings.backgroundcolor }};
  }

  .product-info-container {
    max-width: 1280px;
    width: 90%;
    margin: 0 auto;
  }

  .product-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .product-info-left {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-title {
    font-size: {{ section.settings.titlefontsize }}px;
    font-weight: bold;
    color: {{ section.settings.titlecolor }};
    margin: 0;
    line-height: 1.1;
  }

  .product-description {
    font-size: {{ section.settings.descriptionfontsize }}px;
    color: {{ section.settings.descriptioncolor }};
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    font-size: {{ section.settings.pricefontsize }}px;
    font-weight: 600;
    color: {{ section.settings.pricecolor }};
    align-items: center;
  }

  .price-old {
    color: {{ section.settings.oldpricecolor }};
    text-decoration: line-through;
  }

  .price-discount {
    color: {{ section.settings.discountcolor }};
    font-weight: bold;
  }

  .sku-selector {
    margin: 1rem 0;
  }

  .sku-selector h3 {
    font-size: {{ section.settings.skutitlefontsize }}px;
    color: {{ section.settings.skutitlecolor }};
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .sku-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sku-option {
    position: relative;
  }

  .sku-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .sku-option label {
    display: block;
    padding: 0.5rem 0.75rem;
    border: 2px solid {{ section.settings.skubordercolor }};
    border-radius: {{ section.settings.skuborderradius }}px;
    background: {{ section.settings.skubackgroundcolor }};
    color: {{ section.settings.skutextcolor }};
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: {{ section.settings.skufontsize }}px;
    font-weight: 500;
    text-align: center;
    min-width: 70px;
  }

  .sku-option input[type="radio"]:checked + label {
    border-color: #9ABD48;
    background: #9ABD48;
    color: white;
  }

  .sku-option label:hover {
    border-color: #9ABD48;
  }

  .quantity-selector {
    margin: 0.75rem 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .quantity-selector label {
    font-size: {{ section.settings.quantityfontsize }}px;
    color: {{ section.settings.quantitycolor }};
    font-weight: 600;
  }

  .quantity-input {
    display: flex;
    align-items: center;
    border: 2px solid {{ section.settings.quantitybordercolor }};
    border-radius: {{ section.settings.quantityborderradius }}px;
    overflow: hidden;
  }

  .quantity-btn {
    background: {{ section.settings.quantitybtnbackground }};
    color: {{ section.settings.quantitybtncolor }};
    border: none;
    padding: 0.4rem 0.6rem;
    cursor: pointer;
    font-size: 16px;
    font-weight: bold;
    transition: background 0.3s ease;
  }

  .quantity-btn:hover {
    background: #9ABD48;
    color: white;
  }

  .quantity-number {
    padding: 0.4rem 0.75rem;
    border: none;
    text-align: center;
    font-size: {{ section.settings.quantityfontsize }}px;
    font-weight: 600;
    width: 50px;
    background: white;
  }

  .bulk-discount-section {
    margin: 1rem 0;
    padding: 1rem 0 0.5rem;
  }

  .bulk-discount-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.skutitlecolor }};
    text-transform: none;
  }

  .bulk-discount-header::before,
  .bulk-discount-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
  }

  .bulk-discount-tiers {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bulk-tier-option {
    position: relative;
  }

  .bulk-tier-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .bulk-tier-label {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background: #fff;
  }

  .bulk-tier-option input[type="radio"]:checked + .bulk-tier-label {
    border: 2px solid #1f2937;
  }

  .bulk-tier-radio {
    width: 18px;
    height: 18px;
    border: 2px solid #d1d5db;
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .bulk-tier-option input[type="radio"]:checked + .bulk-tier-label .bulk-tier-radio {
    border-color: #1f2937;
  }

  .bulk-tier-option input[type="radio"]:checked + .bulk-tier-label .bulk-tier-radio::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    background: #1f2937;
    border-radius: 50%;
  }

  .bulk-tier-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .bulk-tier-title {
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.3;
  }

  .bulk-tier-discount {
    font-size: 12px;
    color: #6b7280;
    font-weight: 500;
  }

  .bulk-tier-prices {
    text-align: right;
    flex-shrink: 0;
  }

  .bulk-tier-price {
    font-size: 15px;
    font-weight: 700;
    color: #1f2937;
    display: block;
    line-height: 1.2;
  }

  .bulk-tier-compare {
    font-size: 12px;
    color: #9ca3af;
    text-decoration: line-through;
    display: block;
    line-height: 1.2;
  }

  .bulk-tier-badge {
    position: absolute;
    top: -8px;
    right: 12px;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
    background: #c45c26;
    line-height: 1.4;
    white-space: nowrap;
    z-index: 1;
  }

  .bulk-discount-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
    padding-top: 0.25rem;
    font-size: 13px;
  }

  .bulk-urgency-text {
    color: #6b7280;
    font-size: 12px;
  }

  .bulk-total-label {
    font-weight: 700;
    color: #1f2937;
    font-size: 15px;
  }

  .bulk-total-label span {
    font-weight: 700;
  }

  .total-row.is-hidden {
    display: none;
  }

  .benefits-list {
    margin: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .benefit-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: {{ section.settings.benefitfontsize }}px;
    color: {{ section.settings.benefitcolor }};
  }

  .benefit-item .value {
    color: {{ section.settings.benefitvaluecolor }};
    font-weight: normal;
  }

  .total-row {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    font-size: {{ section.settings.totalfontsize }}px;
    font-weight: bold;
    color: {{ section.settings.totalcolor }};
  }

  .shipping-info {
    margin-bottom: 0.5rem;
    font-size: {{ section.settings.descriptionfontsize }}px;
    color: {{ section.settings.descriptioncolor }};
  }

  .shipping-info p {
    margin: 0px;
  }

  .disclaimer {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: {{ section.settings.disclaimercolor }};
    line-height: 1.4;
  }

  .disclaimer p {
    margin: 0.25rem 0;
  }

  .guarantee {
    margin-top: 0.75rem;
    font-weight: 600;
    color: {{ section.settings.guaranteecolor }};
    font-size: 0.9rem;
  }

  .guarantee p {
    margin: 0.25rem 0;
  }

  .flexible {
    font-size: 0.8rem;
    color: {{ section.settings.flexiblecolor }};
  }

  .flexible p {
    margin: 0.25rem 0;
  }

  .button-group {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    flex-direction: column;
  }

  .add-to-cart-button, .buy-now-button {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: {{ section.settings.buttonborderradius }}px;
    font-size: {{ section.settings.buttonfontsize }}px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    width: 100%;
  }

  .add-to-cart-button {
    background: {{ section.settings.addtocartbgcolor }};
    color: {{ section.settings.addtocarttextcolor }};
    border: 2px solid #9ABD48;
  }

  .add-to-cart-button:hover {
    background: #9ABD48;
    color: white;
    transform: translateY(-1px);
  }

  .buy-now-button {
    background: #9ABD48;
    color: white;
  }

  .buy-now-button:hover {
    background: #8aa63f;
    transform: translateY(-1px);
  }

  .image-container {
    width: 100%;
    max-width: 630px;
    height: 700px;
    display: flex;
    align-items: center;
    /* justify-content: flex-end; */
    border-radius: {{ section.settings.imageborderradius }}px;
    /* overflow: hidden; */
    position: relative;
    flex-direction: column;
  }

  .main-image {
    max-width: 100%;

    width: auto;
    height: {{ section.settings.imageheight }}px;
    object-fit: contain;
    border-radius: {{ section.settings.imageborderradius }}px;
    transition: opacity 0.3s ease;
  }

  .main-image.changing {
    opacity: 0.7;
  }

  .placeholder-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9ca3af;
    font-size: 16px;
    background: #f9fafb;
    border-radius: {{ section.settings.imageborderradius }}px;
    border: 2px dashed #d1d5db;
  }

  .thumbnail-gallery {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    overflow-x: auto;
    padding: 8px 16px;
    width: 100%;
    scrollbar-width: thin;
    /* position: absolute;
    bottom: -100px; */
  }

  @media (max-width: 768px) {
    .thumbnail-gallery {
      max-width: 100% ;
      padding: 8px;
    }
  }

  .thumbnail {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid #e5e7eb;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .thumbnail:hover {
    border-color: #9ABD48;
  }

  .thumbnail.active {
    border: 2px solid #9ABD48;
  }

  .product-form {
    width: 100%;
  }

  @media (max-width: 768px) {
    .product-info-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .product-info-left {
      gap: 0.5rem;
    }

    .product-title {
      font-size: {{ section.settings.titlefontsizemobile }}px;
    }

    .benefit-item, .price-row, .total-row {
      font-size: {{ section.settings.benefitfontsizemobile }}px;
    }

    .benefit-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .total-row {
      flex-direction: row;
      justify-content: space-between;
    }

    .button-group {
      flex-direction: column;
      gap: 0.5rem;
    }

    .sku-options {
      justify-content: center;
    }

    .quantity-selector {
      justify-content: center;
    }

    .image-container {
      justify-content: center;
      height: auto;
      max-width: 83vw;
      max-height: 500px;
      padding-bottom: 20px;
    }

    .main-image {
      height: auto;
      max-height: 300px;
    }

    .thumbnail-gallery {
      position: static;
      margin-top: 10px;
      padding: 8px 0;
      width: 100%;
    }
  }
</style>

{% comment %}
  Product Info Section - Multi-SKU Support + Thumbnail Filtering by SKU Number
{% endcomment %}

{% liquid
  assign displayproduct = product
  if section.settings.selectedproduct != blank
    assign displayproduct = all_products[section.settings.selectedproduct]
  elsif displayproduct == blank and collections.all.products.size > 0
    assign displayproduct = collections.all.products.first
  endif
%}

<section class="product-info-section">
  <div class="product-info-container">
    <div class="product-info-grid">
      <!-- Left Content -->
      <div class="product-info-left">
        <h1 class="product-title">
          {% if section.settings.useproducttitle %}
            {{ displayproduct.title }}
          {% else %}
            {{ section.settings.producttitle | default: displayproduct.title }}
          {% endif %}
        </h1>

        <div class="product-description">
          {% if section.settings.useproductdescription %}
            {{ displayproduct.description }}
          {% else %}
            {{ section.settings.productdescription | default: displayproduct.description }}
          {% endif %}
        </div>

        <div class="price-row">
          <span id="current-price">
            {% if displayproduct.compare_at_price > displayproduct.price %}
              {{ displayproduct.price | money }}
            {% else %}
              {{ displayproduct.price | money }}
            {% endif %}
          </span>
          {% if displayproduct.compare_at_price > displayproduct.price %}
            <span class="price-old price-discount" id="old-price">{{ displayproduct.compare_at_price | money }}</span>
          {% endif %}
        </div>

        {% if section.settings.shippinginfo != blank %}
          <div class="shipping-info">{{ section.settings.shippinginfo }}</div>
        {% endif %}

        <form class="product-form" action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
          {% if displayproduct.variants.size > 1 %}
            <div class="sku-selector">
              <h3>{{ section.settings.skuselectortitle }}</h3>
              <div class="sku-options">
                {% for variant in displayproduct.variants %}
                  <div class="sku-option">
                    <input
                      type="radio"
                      id="variant-{{ variant.id }}"
                      name="id"
                      value="{{ variant.id }}"
                      data-price="{{ variant.price | money }}"
                      data-price-cents="{{ variant.price }}"
                      data-old-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                      data-available="{{ variant.available }}"
                      data-image="{% if variant.image %}{{ variant.image | image_url: width: 800 }}{% elsif displayproduct.featured_image %}{{ displayproduct.featured_image | image_url: width: 800 }}{% endif %}"
                      data-image-alt="{% if variant.image %}{{ variant.image.alt | default: variant.title }}{% else %}{{ displayproduct.featured_image.alt | default: displayproduct.title }}{% endif %}"
                      {% if forloop.first %}checked{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                    <label for="variant-{{ variant.id }}">{{ variant.title }}</label>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ displayproduct.selected_or_first_available_variant.id }}">
          {% endif %}

          {%- assign has_bulk_tiers = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'bulk_tier' -%}
              {%- assign has_bulk_tiers = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign show_bulk_discount = false -%}
          {%- if section.settings.show_bulk_discount -%}
            {%- if has_bulk_tiers -%}
              {%- assign show_bulk_discount = true -%}
            {%- endif -%}
          {%- endif -%}
          {%- assign initial_variant = displayproduct.selected_or_first_available_variant -%}
          {%- if displayproduct.variants.size > 1 -%}
            {%- for variant in displayproduct.variants -%}
              {%- if forloop.first -%}
                {%- assign initial_variant = variant -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- assign default_qty = 1 -%}
          {%- if show_bulk_discount -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'bulk_tier' -%}
                {%- if block.settings.default_selected -%}
                  {%- assign default_qty = block.settings.quantity -%}
                  {%- break -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if default_qty == 1 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'bulk_tier' -%}
                  {%- assign default_qty = block.settings.quantity -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}

          <div class="quantity-selector">
            <label for="quantity">{{ section.settings.quantitylabel }}:</label>
            <div class="quantity-input">
              <button type="button" class="quantity-btn" data-qty-change="-1">−</button>
              <input
                type="number"
                id="quantity"
                name="quantity"
                value="{% if show_bulk_discount %}{{ default_qty }}{% else %}1{% endif %}"
                min="1"
                class="quantity-number"
                readonly
              >
              <button type="button" class="quantity-btn" data-qty-change="1">+</button>
            </div>
          </div>

          {%- if show_bulk_discount -%}
            {%- assign default_tier_discount = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'bulk_tier' -%}
                {%- if block.settings.quantity == default_qty -%}
                  {%- assign default_tier_discount = block.settings.discount_percent -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign default_subtotal = initial_variant.price | times: default_qty -%}
            {%- assign default_discount_amount = default_subtotal | times: default_tier_discount | divided_by: 100 -%}
            {%- assign default_final = default_subtotal | minus: default_discount_amount -%}

            <div
              class="bulk-discount-section"
              id="bulk-discount-{{ section.id }}"
              data-money-format="{{ shop.money_format | escape }}"
              data-unit-price="{{ initial_variant.price }}"
            >
              <div class="bulk-discount-header">{{ section.settings.bulk_discount_title }}</div>
              <div class="bulk-discount-tiers">
                {%- for block in section.blocks -%}
                  {%- if block.type != 'bulk_tier' -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- assign tier_qty = block.settings.quantity -%}
                  {%- assign tier_discount = block.settings.discount_percent -%}
                  {%- assign tier_subtotal = initial_variant.price | times: tier_qty -%}
                  {%- assign tier_discount_amount = tier_subtotal | times: tier_discount | divided_by: 100 -%}
                  {%- assign tier_final = tier_subtotal | minus: tier_discount_amount -%}
                  {%- assign tier_id = 'bulk-tier-' | append: section.id | append: '-' | append: block.id -%}
                  <div class="bulk-tier-option" {{ block.shopify_attributes }}>
                    <input
                      type="radio"
                      name="bulk-tier-{{ section.id }}"
                      id="{{ tier_id }}"
                      value="{{ tier_qty }}"
                      data-discount="{{ tier_discount }}"
                      {% if tier_qty == default_qty %}checked{% endif %}
                    >
                    <label class="bulk-tier-label" for="{{ tier_id }}">
                      {%- if block.settings.badge == 'most_popular' -%}
                        <span class="bulk-tier-badge">{{ section.settings.badge_most_popular }}</span>
                      {%- elsif block.settings.badge == 'wholesale' -%}
                        <span class="bulk-tier-badge">{{ section.settings.badge_wholesale }}</span>
                      {%- endif -%}
                      <span class="bulk-tier-radio" aria-hidden="true"></span>
                      <span class="bulk-tier-info">
                        <span class="bulk-tier-title">
                          {{ tier_qty }} {{ block.settings.quantity_label }}
                          {%- if block.settings.pcs_label != blank -%}
                            ({{ block.settings.pcs_label }})
                          {%- endif -%}
                        </span>
                        {%- if tier_discount > 0 -%}
                          <span class="bulk-tier-discount">{{ tier_discount }}% OFF</span>
                        {%- endif -%}
                      </span>
                      <span class="bulk-tier-prices">
                        <span class="bulk-tier-price" data-tier-price>{{ tier_final | money }}</span>
                        {%- if tier_discount > 0 -%}
                          <span class="bulk-tier-compare" data-tier-compare>{{ tier_subtotal | money }}</span>
                        {%- endif -%}
                      </span>
                    </label>
                  </div>
                {%- endfor -%}
              </div>
              <div class="bulk-discount-footer">
                {%- if section.settings.urgency_text != blank -%}
                  <span class="bulk-urgency-text">{{ section.settings.urgency_text }}</span>
                {%- else -%}
                  <span></span>
                {%- endif -%}
                <span class="bulk-total-label">
                  {{ section.settings.totallabel }}:
                  <span id="total-price">{{ default_final | money }}</span>
                </span>
              </div>
            </div>
          {%- endif -%}

          <div class="total-row{% if show_bulk_discount %} is-hidden{% endif %}">
            <span>{{ section.settings.totallabel }}</span>
            <span id="{% if show_bulk_discount %}total-price-fallback{% else %}total-price{% endif %}">{{ displayproduct.price | money }}</span>
          </div>

          <div class="button-group">
            <button type="submit" name="add" class="add-to-cart-button" id="add-to-cart-btn">
              {{ section.settings.addtocarttext }}
            </button>
            <button type="button" class="buy-now-button" id="buy-now-btn">
              {{ section.settings.buynowtext }}
            </button>
          </div>
        </form>
      </div>

      <!-- Right Image -->
      <div class="image-container">
        {%- assign imageobj = nil -%}
        {%- assign imagealt = section.settings.mainimagealt | default: displayproduct.title -%}

        {%- if section.settings.useproductimage and displayproduct.featured_image -%}
          {%- assign imageobj = displayproduct.featured_image -%}
          {%- assign imagealt = displayproduct.featured_image.alt | default: displayproduct.title -%}
        {%- elsif section.settings.mainimage != blank -%}
          {%- assign imageobj = section.settings.mainimage -%}
        {%- elsif section.settings.fallbackimage != blank -%}
          {%- assign imageobj = section.settings.fallbackimage -%}
        {%- elsif displayproduct.featured_image -%}
          {%- assign imageobj = displayproduct.featured_image -%}
          {%- assign imagealt = displayproduct.featured_image.alt | default: displayproduct.title -%}
        {%- endif -%}

        {%- if imageobj != blank -%}
          <img
            id="main-product-image"
            src="{{ imageobj | image_url: width: 800 }}"
            alt="{{ imagealt }}"
            class="main-image"
            width="800"
            height="800"
            loading="eager"
          >
          <div class="placeholder-image" style="display: none;">
            <span>{{ displayproduct.title | default: 'Product Image' }}</span>
          </div>
        {%- else -%}
          <div id="main-product-image" class="placeholder-image">
            <span>{{ displayproduct.title | default: 'No Image Available' }}</span>
          </div>
        {%- endif -%}

        {% if displayproduct.images.size > 1 %}
          <div class="thumbnail-gallery">
            {% for image in displayproduct.images %}
              {%- assign keytext = image.src | downcase -%}
              {%- assign filename = image.src | split: '/' | last | split: '.' | first -%}
              {%- comment -%} 从文件名格式 '12oz_2_B' 中提取中间的数字 '2' {%- endcomment -%}
              {%- assign filename_parts = filename | split: '_' -%}
              {%- assign sort_number_raw = '' -%}
              {%- if filename_parts.size >= 2 -%}
                {%- assign sort_number_raw = filename_parts[1] -%}
              {%- endif -%}
              {%- comment -%} 检查提取的数字是否有效，如果无效则使用循环索引作为备用 {%- endcomment -%}
              {%- assign sort_number = sort_number_raw -%}
              {%- unless sort_number_raw contains '0' or sort_number_raw contains '1' or sort_number_raw contains '2' or sort_number_raw contains '3' or sort_number_raw contains '4' or sort_number_raw contains '5' or sort_number_raw contains '6' or sort_number_raw contains '7' or sort_number_raw contains '8' or sort_number_raw contains '9' -%}
                {%- assign sort_number = forloop.index -%}
              {%- endunless -%}
              <img
                src="{{ image | image_url: width: 100 }}"
                alt="{{ image.alt | default: displayproduct.title }}"
                class="thumbnail{% if forloop.first %} active{% endif %}"
                width="100"
                height="100"
                loading="lazy"
                data-image-key="{{ keytext }}"
                data-sort-number="{{ sort_number }}"
                data-filename="{{ filename }}"
                data-main-image="{{ image | image_url: width: 800 }}"
                data-main-image-webp=""
                onclick="switchMainImage(this)"
              >
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  const SHOP_MONEY_FORMAT = {{ shop.money_format | json }};
  const LIQUID_OPEN = '{' + '{';
  const LIQUID_CLOSE = '}' + '}';
  const LIQUID_AMOUNT_TOKEN = LIQUID_OPEN + 'amount' + LIQUID_CLOSE;
  const LIQUID_AMOUNT_NO_DECIMALS_TOKEN = LIQUID_OPEN + 'amount_no_decimals' + LIQUID_CLOSE;
  const LIQUID_AMOUNT_COMMA_TOKEN = LIQUID_OPEN + 'amount_with_comma_separator' + LIQUID_CLOSE;

  // 按数字排序缩略图的函数
  function sortThumbnailsByNumber() {
    
    
    const gallery = document.querySelector('.thumbnail-gallery');
    if (!gallery) {
      return;
    }
    
    const thumbnails = Array.from(gallery.querySelectorAll('.thumbnail'));
    if (thumbnails.length === 0) {
      return;
    }
    
    
    
    // 按数字排序，增强异常处理
    thumbnails.sort((a, b) => {
      const sortNumA = a.getAttribute('data-sort-number');
      const sortNumB = b.getAttribute('data-sort-number');

      // 回退：从文件名中提取第一个下划线后的数字
      const fallbackParse = (el) => {
        const fn = el.getAttribute('data-filename') || '';
        const match = fn.match(/_(\d+)/);
        return match ? parseInt(match[1], 10) : NaN;
      };

      // 优先用 data-sort-number，否则用回退解析
      const parsedA = parseInt(sortNumA, 10);
      const parsedB = parseInt(sortNumB, 10);
      const numA = !isNaN(parsedA) ? parsedA : fallbackParse(a);
      const numB = !isNaN(parsedB) ? parsedB : fallbackParse(b);

      // 如果都是有效数字，按数字排序
      if (!isNaN(numA) && !isNaN(numB)) {
        return numA - numB;
      }

      // 如果只有一个是有效数字，有效数字排在前面
      if (!isNaN(numA) && isNaN(numB)) return -1;
      if (isNaN(numA) && !isNaN(numB)) return 1;

      // 如果都不是有效数字，按文件名字母顺序排序
      const filenameA = a.getAttribute('data-filename') || '';
      const filenameB = b.getAttribute('data-filename') || '';
      return filenameA.localeCompare(filenameB);
    });
    
    
    
    // 重新排列DOM元素
    thumbnails.forEach(thumb => gallery.appendChild(thumb));
    
    
    // 激活第一个缩略图
    thumbnails.forEach(thumb => thumb.classList.remove('active'));
    if (thumbnails.length > 0) {
      thumbnails[0].classList.add('active');
      
      // 更新主图为第一个缩略图
      const firstThumb = thumbnails[0];
      const mainImage = document.getElementById('main-product-image');
      const picture = mainImage.parentElement;
      const webpSource = picture.querySelector('source[type="image/webp"]');
      
      if (mainImage && firstThumb) {
        const newImageSrc = firstThumb.getAttribute('data-main-image');
        const newImageWebp = firstThumb.getAttribute('data-main-image-webp');
        
        
        
        if (webpSource && newImageWebp) {
          webpSource.srcset = newImageWebp;
        }
        mainImage.src = newImageSrc;
        mainImage.alt = firstThumb.alt;
        
        
      }
    }
    
    
  }

  // 图片切换函数 - 带渐隐过渡效果
  function switchMainImage(thumbnail) {
    
    const mainImage = document.getElementById('main-product-image');
    const picture = mainImage.parentElement;
    const webpSource = picture.querySelector('source[type="image/webp"]');
    
    const newImageSrc = thumbnail.getAttribute('data-main-image');
    const newImageWebp = thumbnail.getAttribute('data-main-image-webp');
    const newImageAlt = thumbnail.alt;
    
    
    
    if (!mainImage || !newImageSrc || mainImage.src === newImageSrc) {
      return;
    }
    
    
    // 添加过渡效果
    mainImage.style.transition = 'opacity 0.3s ease';
    mainImage.style.opacity = '0.3';
    
    // 预加载新图片（只有支持WebP的格式才尝试WebP）
    const preloadImage = new Image();
    preloadImage.onload = function() {
      // 只有当WebP源存在且不为空时才更新WebP source
      if (webpSource && newImageWebp && newImageWebp.trim() !== '') {
        webpSource.srcset = newImageWebp;
      }
      
      mainImage.src = newImageSrc;
      mainImage.alt = newImageAlt;
      mainImage.style.opacity = '1';

      
      
      // 更新缩略图active状态
      const allThumbs = document.querySelectorAll('.thumbnail');
      allThumbs.forEach(thumb => thumb.classList.remove('active'));
      thumbnail.classList.add('active');
      
      
    };
    
    preloadImage.onerror = function() {
      
      // 如果WebP加载失败，尝试原格式
      const fallbackImage = new Image();
      fallbackImage.onload = function() {
        mainImage.src = newImageSrc;
        mainImage.alt = newImageAlt;
        mainImage.style.opacity = '1';
        
        const allThumbs = document.querySelectorAll('.thumbnail');
        allThumbs.forEach(thumb => thumb.classList.remove('active'));
        thumbnail.classList.add('active');
      };
      fallbackImage.onerror = function() {
        mainImage.style.opacity = '1';
      };
      fallbackImage.src = newImageSrc;
    };
    
    // 优先尝试WebP格式（如果存在且不为空）
    preloadImage.src = (newImageWebp && newImageWebp.trim() !== '') ? newImageWebp : newImageSrc;
  }

  function formatMoney(cents, moneyFormat) {
    const amount = (cents / 100).toFixed(2);
    const format = moneyFormat || SHOP_MONEY_FORMAT;
    if (!format) return '$' + amount;
    return format
      .split(LIQUID_AMOUNT_TOKEN).join(amount)
      .split(LIQUID_AMOUNT_NO_DECIMALS_TOKEN).join(Math.round(cents / 100).toString())
      .split(LIQUID_AMOUNT_COMMA_TOKEN).join(amount.replace('.', ','));
  }

  function getBulkDiscountState() {
    const bulkSection = document.querySelector('.bulk-discount-section');
    if (!bulkSection) return null;

    const quantityInput = document.getElementById('quantity');
    const tierRadios = bulkSection.querySelectorAll('input[name^="bulk-tier-"]');
    const unitPrice = parseInt(bulkSection.getAttribute('data-unit-price'), 10) || 0;
    const moneyFormat = bulkSection.getAttribute('data-money-format') || SHOP_MONEY_FORMAT;

    return { bulkSection, quantityInput, tierRadios, unitPrice, moneyFormat };
  }

  function getTierTotals(unitPriceCents, quantity, discountPercent) {
    const subtotal = unitPriceCents * quantity;
    const discountAmount = Math.round(subtotal * discountPercent / 100);
    return {
      subtotal,
      final: subtotal - discountAmount
    };
  }

  function updateBulkTierPrices(unitPriceCents, moneyFormat) {
    const bulkState = getBulkDiscountState();
    if (!bulkState) return;

    bulkState.tierRadios.forEach(function (radio) {
      const quantity = parseInt(radio.value, 10) || 1;
      const discount = parseInt(radio.getAttribute('data-discount'), 10) || 0;
      const totals = getTierTotals(unitPriceCents, quantity, discount);
      const label = radio.nextElementSibling;
      if (!label) return;

      const priceEl = label.querySelector('[data-tier-price]');
      const compareEl = label.querySelector('[data-tier-compare]');
      if (priceEl) priceEl.textContent = formatMoney(totals.final, moneyFormat);
      if (compareEl) compareEl.textContent = formatMoney(totals.subtotal, moneyFormat);
    });
  }

  function selectBulkTierByQuantity(quantity) {
    const bulkState = getBulkDiscountState();
    if (!bulkState) return;

    let matched = null;
    let bestLower = null;
    bulkState.tierRadios.forEach(function (radio) {
      const tierQty = parseInt(radio.value, 10) || 0;
      if (tierQty === quantity) matched = radio;
      if (tierQty <= quantity) {
        if (!bestLower || tierQty > parseInt(bestLower.value, 10)) {
          bestLower = radio;
        }
      }
    });

    const target = matched || bestLower || bulkState.tierRadios[0];
    if (target) {
      target.checked = true;
    }
  }

  function updateTotalPrice() {
    const quantityInput = document.getElementById('quantity');
    const totalPriceElement = document.getElementById('total-price');
    const bulkState = getBulkDiscountState();

    if (!quantityInput || !totalPriceElement) return;

    const quantity = parseInt(quantityInput.value, 10) || 1;

    if (bulkState) {
      const selectedTier = bulkState.bulkSection.querySelector('input[name^="bulk-tier-"]:checked');
      const discount = selectedTier ? parseInt(selectedTier.getAttribute('data-discount'), 10) || 0 : 0;
      const totals = getTierTotals(bulkState.unitPrice, quantity, discount);
      totalPriceElement.textContent = formatMoney(totals.final, bulkState.moneyFormat);
      return;
    }

    const currentPriceElement = document.getElementById('current-price');
    if (!currentPriceElement) return;

    const priceText = currentPriceElement.textContent.trim();
    const amountMatch = priceText.match(/[0-9][0-9,.]*/);
    if (!amountMatch) return;
    const price = parseFloat(amountMatch[0].replace(/,/g, '')) || 0;
    const total = quantity * price;
    const formattedTotal = total.toLocaleString(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });
    totalPriceElement.textContent = priceText.replace(amountMatch[0], formattedTotal);
  }

  function changeQuantity(change) {
    const quantityInput = document.getElementById('quantity');
    if (!quantityInput) return;

    let num = parseInt(quantityInput.value, 10) || 1;
    num = num + change;
    if (num < 1) num = 1;
    quantityInput.value = num;
    selectBulkTierByQuantity(num);
    updateTotalPrice();
  }

  // 异步初始化产品功能
  function initializeProductSection() {
    const variantOptions = document.querySelectorAll('input[name="id"]');
    const currentPriceElement = document.getElementById('current-price');
    const oldPriceElement = document.getElementById('old-price');
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    const buyNowBtn = document.getElementById('buy-now-btn');
    const bulkState = getBulkDiscountState();

    document.querySelectorAll('[data-qty-change]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        changeQuantity(parseInt(this.getAttribute('data-qty-change'), 10));
      });
    });

    if (bulkState) {
      bulkState.tierRadios.forEach(function (radio) {
        radio.addEventListener('change', function () {
          if (!this.checked) return;
          bulkState.quantityInput.value = parseInt(this.value, 10) || 1;
          updateTotalPrice();
        });
      });

      const initialQty = parseInt(bulkState.quantityInput.value, 10) || 1;
      selectBulkTierByQuantity(initialQty);
    }

    updateTotalPrice();

    variantOptions.forEach(function (option) {
      option.addEventListener('change', function () {
        if (!this.checked) return;

        const newPrice = this.getAttribute('data-price');
        const newOldPrice = this.getAttribute('data-old-price');
        const isAvailable = this.getAttribute('data-available') === 'true';
        const newImage = this.getAttribute('data-image');
        const newImageAlt = this.getAttribute('data-image-alt');
        const variantTitle = this.nextElementSibling.textContent;

        if (newPrice) currentPriceElement.textContent = newPrice;
        if (newOldPrice && newOldPrice !== '') {
          if (!document.getElementById('old-price')) {
            const priceRow = document.querySelector('.price-row');
            const oldPriceSpan = document.createElement('span');
            oldPriceSpan.className = 'price-old price-discount';
            oldPriceSpan.id = 'old-price';
            priceRow.appendChild(oldPriceSpan);
          }
          document.getElementById('old-price').textContent = newOldPrice;
          document.getElementById('old-price').style.display = 'inline';
        } else if (oldPriceElement) {
          oldPriceElement.style.display = 'none';
        }

        // 添加错误处理
        try {
          
          
          // 🧩 根据变体名称中的数字+oz组合过滤缩略图
          const variantTitle = this.nextElementSibling.textContent.toLowerCase();
          const ozMatch = variantTitle.match(/(\d+)oz/);
          const variantOzPattern = ozMatch ? ozMatch[1] + 'oz' : '';
          
          
          
          const thumbnails = document.querySelectorAll('.thumbnail');
          const mainImage = document.getElementById('main-product-image');
          
          

          // 先过滤缩略图并移除 active 状态
          const visibleThumbnails = [];
          thumbnails.forEach((thumb, index) => {
            const key = thumb.getAttribute('data-image-key').toLowerCase();
            const shouldShow = variantOzPattern && key.includes(variantOzPattern);
            const displayStyle = shouldShow ? 'inline-block' : (variantOzPattern ? 'none' : 'inline-block');
            
            
            
            thumb.style.display = displayStyle;
            thumb.classList.remove('active');
            
            // 收集可见的缩略图用于排序
            if (displayStyle !== 'none') {
              visibleThumbnails.push(thumb);
            }
          });

          

          // 对可见的缩略图按数字排序，增强异常处理
          
          visibleThumbnails.sort((a, b) => {
            const sortNumA = a.getAttribute('data-sort-number');
            const sortNumB = b.getAttribute('data-sort-number');

            // 回退：从文件名中提取第一个下划线后的数字
            const fallbackParse = (el) => {
              const fn = el.getAttribute('data-filename') || '';
              const match = fn.match(/_(\d+)/);
              return match ? parseInt(match[1], 10) : NaN;
            };

            // 优先用 data-sort-number，否则用回退解析
            const parsedA = parseInt(sortNumA, 10);
            const parsedB = parseInt(sortNumB, 10);
            const numA = !isNaN(parsedA) ? parsedA : fallbackParse(a);
            const numB = !isNaN(parsedB) ? parsedB : fallbackParse(b);

            // 如果都是有效数字，按数字排序
            if (!isNaN(numA) && !isNaN(numB)) {
              return numA - numB;
            }

            // 如果只有一个是有效数字，有效数字排在前面
            if (!isNaN(numA) && isNaN(numB)) return -1;
            if (isNaN(numA) && !isNaN(numB)) return 1;

            // 如果都不是有效数字，按文件名字母顺序排序
            const filenameA = a.getAttribute('data-filename') || '';
            const filenameB = b.getAttribute('data-filename') || '';
            return filenameA.localeCompare(filenameB);
          });

          

          // 使用排序后的第一个可见缩略图来更新主图
          let finalImageSrc = null;
          let finalImageAlt = '';

          if (visibleThumbnails.length > 0) {
            const firstVisibleThumb = visibleThumbnails[0];
            finalImageSrc = firstVisibleThumb.getAttribute('data-main-image');
            finalImageAlt = firstVisibleThumb.alt || '';
            firstVisibleThumb.classList.add('active');
            
            
          } else {
            
          }

          // 更新主图
          if (finalImageSrc && mainImage) {
            const picture = mainImage.parentElement;
            const webpSource = picture.querySelector('source[type="image/webp"]');
            const webpSrc = visibleThumbnails[0]?.getAttribute('data-main-image-webp');
            
            if (webpSource && webpSrc) {
              webpSource.srcset = webpSrc;
            }
            mainImage.src = finalImageSrc;
            mainImage.alt = finalImageAlt;
          }
        } catch (error) {
          
        }

        // 更新按钮状态
        addToCartBtn.disabled = !isAvailable;
        buyNowBtn.disabled = !isAvailable;
        addToCartBtn.textContent = isAvailable ? '{{ section.settings.addtocarttext }}' : 'Sold Out';

        const bulkSection = document.querySelector('.bulk-discount-section');
        if (bulkSection) {
          const variantPriceCents = parseInt(this.getAttribute('data-price-cents') || '0', 10);
          if (variantPriceCents > 0) {
            bulkSection.setAttribute('data-unit-price', variantPriceCents);
            updateBulkTierPrices(variantPriceCents, bulkSection.getAttribute('data-money-format') || SHOP_MONEY_FORMAT);
          }
        }

        updateTotalPrice();
      });
    });

    // Buy now - redirect to checkout
    document.getElementById('buy-now-btn').addEventListener('click', function () {
      const form = document.querySelector('.product-form');
      const formData = new FormData(form);
      fetch('{{ routes.cart_add_url }}.js', { method: 'POST', body: formData })
        .then(() => { window.location.href = '/checkout'; })
        .catch(() => {});
    });

    updateTotalPrice();

    // 页面载入时按数字排序缩略图
    sortThumbnailsByNumber();

    // 页面载入时按默认变体自动过滤
    const firstChecked = document.querySelector('input[name="id"]:checked');
    if (firstChecked) firstChecked.dispatchEvent(new Event('change'));
  }



  // 使用异步延迟初始化，提升首次渲染速度
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(initializeProductSection, 50);
  });
</script>




