      "default": 64
    },
    {
      "type": "color",
      "id": "backgroundcolor",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "image_picker",
      "id": "mainimage",
      "label": "Custom Main Image",
      "info": "Used when 'Use Product Featured Image' is disabled"
    },
    {
      "type": "image_picker",
      "id": "fallbackimage",
      "label": "Fallback Image",
      "info": "Displayed when no product or custom image is available"
    },
    {
      "type": "text",
      "id": "mainimagealt",
      "label": "Image Alt Text",
      "default": "Product Main Image"
    },
    {
      "type": "range",
      "id": "imageheight",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Image Height",
      "default": 450
    },
    {
      "type": "range",
      "id": "imageborderradius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "text",
      "id": "producttitle",
      "label": "Custom Product Title",
      "info": "Used when 'Use Product Title' is disabled"
    },
    {
      "type": "richtext",
      "id": "productdescription",
      "label": "Custom Product Description",
      "info": "Used when 'Use Product Description' is disabled"
    },
    {
      "type": "color",
      "id": "titlecolor",
      "label": "Title Color",
      "default": "#1f2937"
    },
    {
      "type": "range",
      "id": "titlefontsize",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size",
      "default": 36
    },
    {
      "type": "range",
      "id": "titlefontsizemobile",
      "min": 20,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Mobile Title Font Size",
      "default": 30
    },
    {
      "type": "color",
      "id": "descriptioncolor",
      "label": "Description Text Color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "descriptionfontsize",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Description Font Size",
      "default": 18
    },
    {
      "type": "color",
      "id": "pricecolor",
      "label": "Price Color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "oldpricecolor",
      "label": "Original Price Color",
      "default": "#9ca3af"
    },
    {
      "type": "color",
      "id": "discountcolor",
      "label": "Discount Color",
